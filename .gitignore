# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code -- ignore local/generated dirs, track skills and rules
.claude/settings.local.json
.claude/worktrees/
.claude/projects/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Loox review CSV (regenerate with npm run build:reviews when updated)
app/lib/reviews.ly_*.csv

# Raw video / image masters from marketing. Optimized exports live in
# /public/; raw masters stay local for re-encoding and never ship to Vercel.
/raw-assets/

# Blog images re-hosted from Notion at build time (SEO Phase 6). Build
# artifacts: Vercel re-downloads them each build, so they are never committed.
/public/blog/

# Legacy Shopify blog snapshot (SCRUM-1155). Re-pullable at any time with
# `npx tsx scripts/legacy-blog/fetch.ts`; a 440k-char source dump, not source.
/scripts/legacy-blog/.data/
