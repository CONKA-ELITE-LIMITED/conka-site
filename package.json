{
  "name": "conka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:all": "concurrently \"npm run dev\" \"npx convex dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:changed": "FILES=$(git diff --name-only --diff-filter=ACMR HEAD -- '*.ts' '*.tsx'); if [ -n \"$FILES\" ]; then eslint $FILES; else echo 'No changed TS/TSX files to lint.'; fi",
    "build:reviews": "node scripts/build-loox-testimonials.mjs"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ],
  "dependencies": {
    "@shopify/storefront-api-client": "^1.0.9",
    "@vercel/analytics": "^1.6.1",
    "convex": "^1.31.3",
    "next": "16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.5.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
